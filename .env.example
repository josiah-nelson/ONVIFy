# ONVIFy Configuration
# Copy to .env and modify as needed. All values shown are defaults.

# ── Server ────────────────────────────────────
# WEB_UI_PORT=5552
# MEDIAMTX_PORT=8554
# MEDIAMTX_API_PORT=9997
# ONVIF_BASE_PORT=8001
# WSGI_MAX_WORKERS=20

# ── AI / Inference ────────────────────────────
# AI_DEFAULT_MODEL=yolov8n.pt
# AI_INFERENCE_FRAME_WIDTH=640
# AI_COOLDOWN_SECONDS=5.0
# AI_TARGET_INTERVAL=0.50
# AI_CONFIDENCE_THRESHOLD=40
# AI_MOTION_SENSITIVITY=50
# AI_TORCH_THREADS=                  # Auto-detected if blank
# AI_BACKEND=local                   # local | openai_compatible | dedicated
# AI_BACKEND_URL=                    # URL for external inference backend

# ── Streaming ─────────────────────────────────
# MEDIAMTX_VERSION=v1.18.2
# MEDIAMTX_BIN=                         # Optional path/name override; version-checked
# MEDIAMTX_AUTO_DOWNLOAD=true           # Download configured version into data/bin/ on first run
# GRABBER_RECONNECT_BASE=1.0
# GRABBER_RECONNECT_MAX=30.0
# GF_VIDEO_BITRATE=2500k
# GF_VIDEO_BUFSIZE=5000k
# GF_ENCODER_PRESET=ultrafast

# ── Application ───────────────────────────────
# DEBUG=false
# LOG_FORMAT=console                  # console | json
