<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.onvify.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/onvify/.venv/bin/onvify</string>
        <string>--log-format</string>
        <string>json</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/opt/onvify</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/opt/onvify/logs/onvify.log</string>
    <key>StandardErrorPath</key>
    <string>/opt/onvify/logs/onvify-error.log</string>
</dict>
</plist>
